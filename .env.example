# 데이터 저장 백엔드: memory | postgres (기본값: memory)
DATA_BACKEND=memory
# PostgreSQL 연결 문자열 (DATA_BACKEND=postgres일 때 필수)
DATABASE_URL="postgresql://previo:previo@localhost:5432/previo?schema=public"
# Tenant RLS 모드: off | shadow | enforce (기본값: off)
# - off: 기존 동작 유지 (RLS 미적용)
# - shadow: session context 주입만 수행, RLS 강제는 비활성
# - enforce: tenant 대상 테이블 RLS ENABLE/FORCE 적용
TENANT_RLS_MODE=off
# Tenant RLS runtime guard: off | warn | enforce (기본값: off)
# - off: context scope guard 비활성화
# - warn: service/tenant context mismatch를 경고 로그로만 기록
# - enforce: mismatch를 예외로 차단(운영 hardening 시 권장)
TENANT_RLS_RUNTIME_GUARD_MODE=off
# 선택: true|false (기본값: false)
# - true면 TENANT_RLS_MODE=enforce + guard off 조합에서 startup 경고 로그 출력
TENANT_RLS_RUNTIME_GUARD_STARTUP_WARN=false

# API 서버
API_PORT=3001

# 스캔 실행 모드: mock | native (기본값: mock)
SCAN_EXECUTION_MODE=mock
# 스캔 실패 재시도 백오프 기준(ms, 기본값: 100)
SCAN_RETRY_BACKOFF_BASE_MS=100
# 스캔 최대 재시도 횟수(기본값: 2)
SCAN_MAX_RETRIES=2

# 멀티테넌시 인증 강제 모드(기존 호환): disabled | required
TENANT_AUTH_MODE=disabled
# 인증 소스 선택: header | jwt (기본값: header)
AUTH_MODE=header
# tenant 감사 로그 보존 기간(일). 미설정/0/음수/비정수면 보존정책 비활성화(하위호환)
TENANT_AUDIT_LOG_RETENTION_DAYS=

# JWT 인증 설정 (AUTH_MODE=jwt일 때 필수)
JWT_ISSUER="https://issuer.example.com"
JWT_AUDIENCE="previo-api"
JWT_JWKS_URL="https://issuer.example.com/.well-known/jwks.json"

# JWT claim 매핑 (AUTH_MODE=jwt)
# - 기본값은 기존 계약과 동일: tenant_id/tid, sub/user_id, role/roles[0]
# - fallback env는 CSV 형식이며, 빈 문자열("" 또는 공백)로 설정하면 fallback 비활성화
# - selector 형식: <claim> 또는 <claim>[n]
#   * role 값은 owner | admin | member | viewer 중 하나여야 함
JWT_TENANT_ID_CLAIM="tenant_id"
JWT_TENANT_ID_FALLBACK_CLAIMS="tid"
JWT_USER_ID_CLAIM="sub"
JWT_USER_ID_FALLBACK_CLAIMS="user_id"
JWT_ROLE_CLAIM="role"
JWT_ROLE_FALLBACK_CLAIMS="roles[0]"

# Google OIDC (Ops MVP Phase E)
OIDC_GOOGLE_CLIENT_ID="google-client-id"
OIDC_GOOGLE_CLIENT_SECRET="google-client-secret"
OIDC_GOOGLE_REDIRECT_URI="http://localhost:3001/api/v1/auth/google/callback"
# 선택값 (기본값 존재)
# OIDC_GOOGLE_AUTH_URL="https://accounts.google.com/o/oauth2/v2/auth"
# OIDC_GOOGLE_TOKEN_URL="https://oauth2.googleapis.com/token"
# OIDC_GOOGLE_JWKS_URL="https://www.googleapis.com/oauth2/v3/certs"
# OIDC_GOOGLE_ISSUER="https://accounts.google.com"
# OIDC_GOOGLE_SCOPES="openid email profile"
# OIDC_STATE_TTL_SEC=300

# Platform JWT 발급 키
# 미설정 시 API 부팅 시점에 임시 RS256 키를 생성하며 재시작 시 기존 토큰은 무효화됨
PLATFORM_JWT_PRIVATE_KEY_PEM=""
PLATFORM_JWT_PUBLIC_KEY_PEM=""
PLATFORM_JWT_KID="previo-platform-rs256"
PLATFORM_JWT_ISSUER="https://previo.example.com"
PLATFORM_JWT_AUDIENCE="previo-api"
PLATFORM_JWT_ACCESS_TTL_SEC=3600

# Next.js
NEXT_PUBLIC_API_URL="http://localhost:3001"
