# 데이터베이스 연결 (docker-compose.yml 기본값과 일치)
DATABASE_URL="postgresql://devsecops:devsecops@localhost:5432/devsecops?schema=public"

# API 서버
API_PORT=3001

# 스캔 실행 모드: mock | native (기본값: mock)
SCAN_EXECUTION_MODE=mock
# 스캔 실패 재시도 백오프 기준(ms, 기본값: 100)
SCAN_RETRY_BACKOFF_BASE_MS=100
# 스캔 최대 재시도 횟수(기본값: 2)
SCAN_MAX_RETRIES=2

# Next.js
NEXT_PUBLIC_API_URL="http://localhost:3001"
